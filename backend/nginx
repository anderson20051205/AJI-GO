events {
    worker_connections 1024;
}

http {
    upstream auth_service     { server auth:8080; 
    }
    upstream usuarios_service { server usuarios:8000; 
    }
    upstream catalogo_service { server catalogo:8080; 
    }
    upstream pedidos_service  { server pedidos:8080; 
    }

    server {
        listen 80;

        location /api/auth/ {
            proxy_pass         http://auth_service/;
            proxy_set_header   Host              $host;
            proxy_set_header   X-Real-IP         $remote_addr;
        }

        location /api/usuarios/ {
            proxy_pass         http://usuarios_service/;
            proxy_set_header   Host              $host;
            proxy_set_header   X-Real-IP         $remote_addr;
        }

        location /api/catalogo/ {
            proxy_pass         http://catalogo_service/;
            proxy_set_header   Host              $host;
            proxy_set_header   X-Real-IP         $remote_addr;
        }

        location /api/pedidos/ {
            proxy_pass         http://pedidos_service/;
            proxy_set_header   Host              $host;
            proxy_set_header   X-Real-IP         $remote_addr;
        }
    }
}
